# ================================================================================================
# 🏃 PROJECT CONFIGURATION (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific configuration for this repo
# Load Order: 90 (loaded last, overrides all default tool configs)
#
# ================================================================================================

# ================================================================================================
# 📦 GO MODULE CONFIGURATION (overrides 00-core.env)
# ================================================================================================

# Primary Go version for builds and primary test runner
GO_PRIMARY_VERSION=1.25.x
GO_SECONDARY_VERSION=1.25.x
MAGE_X_GO_SECONDARY_VERSION=1.25.x
MAGE_X_GO_VERSION=1.25.x

# Standard go.sum location at repo root
GO_SUM_FILE=go.sum

# ================================================================================================
# 🛡️ CVE EXCLUSION OVERRIDES
# ================================================================================================

# Custom exclusions for AskNancy vulnerability scanning
# NANCY_EXCLUDES=CVE-2024-38513

# Custom exclusions for Govulncheck/Magex vulnerability scanning
# MAGE_X_CVE_EXCLUDES=CVE-2024-38513

# ================================================================================================
# 📊 COVERAGE CONFIGURATION (overrides 10-coverage.env)
# ================================================================================================

# Coverage Provider
GO_COVERAGE_PROVIDER=codecov

# Codecov Configuration
CODECOV_TOKEN_REQUIRED=true

# Coverage Exclusions
GO_COVERAGE_EXCLUDE_PATHS=.github/,.mage-cache/,.vscode/,bin/,docs/,example/,examples/,vendor/,testdata/,testing/
